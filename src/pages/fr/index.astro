---
import Appstores from '../../components/Appstores';
import FeatureImage from '../../components/FeatureImage';
import Gallery from '../../components/Gallery';
import SalesPitch from '../../components/SalesPitch';
import Layout_Body from '../../layouts/Layout_Body.astro';
import type { Language } from '../../types/types_global';

const language = Astro.currentLocale as Language
---

<Layout_Body language={language} >
	
	<FeatureImage language={language} />

	<Appstores language={language} />

	<SalesPitch language={language} />

	<Gallery />

</Layout_Body>
